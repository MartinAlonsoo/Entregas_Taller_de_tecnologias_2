# Variables de entorno para el despliegue en Sepolia
# Copiar este archivo como .env y completar los valores

# URL RPC de Sepolia (obtener en Alchemy o Infura)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/TU_API_KEY_AQUI

# Clave privada del deployer (SIN el prefijo 0x)
PRIVATE_KEY=tu_clave_privada_aqui

# API Key de Etherscan (para verificar el contrato, opcional)
ETHERSCAN_API_KEY=tu_etherscan_api_key_aqui

# Signers del multisig (separados por coma)
SIGNERS=0xDirección1,0xDirección2,0xDirección3

# Umbral de aprobaciones necesarias
THRESHOLD=2
